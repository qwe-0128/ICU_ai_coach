# ============ 骑行AI教练 — 环境变量配置 ============
# 复制此文件为 server/.env 并填入实际值
# 所有密钥仅在 Deno Deploy 服务端使用，永远不会暴露给浏览器

# === Interval.icu ===
INTERVAL_ICU_ATHLETE_ID=i12345
INTERVAL_ICU_API_KEY=your-interval-icu-api-key

# === DeepSeek ===
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# === Supabase ===
SUPABASE_URL=https://yxenbrhyzitcbjisfffq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...（service_role key，不是 anon key）

# === Session Secret（用于 PIN 哈希加盐）===
SESSION_SECRET=生成一个随机字符串（至少32字符）