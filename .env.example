# ============ 骑行AI教练 - 环境变量配置 ============
# 复制此文件为 .env 并填入实际值
# 部署到 Netlify 时在 Dashboard > Site Settings > Environment Variables 中设置

# === Supabase ===
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === interval.icu ===
# 在 https://interval.icu/settings 中获取
INTERVAL_ICU_ATHLETE_ID=
INTERVAL_ICU_API_KEY=

# === DeepSeek ===
# 在 https://platform.deepseek.com/api_keys 中获取
DEEPSEEK_API_KEY=sk-...

# === APP ===
# 6位数字PIN码，用于应用解锁（纯数字，例如 123456）
APP_PIN=123456

# Session JWT 签名密钥（随机字符串，可用 openssl rand -hex 32 生成）
SESSION_SECRET=change-me-to-a-random-string