# Deno Deploy 环境变量（本地开发用，放在 server/.env）
# 部署到 Deno Deploy 时在 Dashboard -> Settings -> Environment Variables 中设置

# Supabase 数据库（同 VITE_SUPABASE_URL）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Interval.icu API
INTERVAL_ICU_API_KEY=你的interval.icu_API密钥
INTERVAL_ICU_ATHLETE_ID=你的运动员ID（数字）

# DeepSeek API
DEEPSEEK_API_KEY=sk-xxx

# 会话密钥（自定义随机字符串，长度≥32）
SESSION_SECRET=your-random-secret-at-least-32-chars